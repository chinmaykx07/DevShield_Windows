# ============================================================
# DevShield — .gitignore
# ============================================================

# ── Build output ─────────────────────────────────────────────
dist/
*.exe
*.dll

# ── Installer output ─────────────────────────────────────────
installer/Output/

# ── Go toolchain ─────────────────────────────────────────────
# go.sum is NOT ignored — it is the cryptographic lock file and
# must be committed so CI and contributors get identical builds.
# go.sum

# Compiled test binaries
*.test

# Go cover output
*.out
coverage.html

# ── User data (never commit ~/.devshield contents) ────────────
# These live in %USERPROFILE%\.devshield\ at runtime, not in
# the repo, but guard against accidental copies here.
audit.db
audit.db-wal
audit.db-shm
state.json
config.json
hardware_profile.json
blocklist_custom.json
events/
backups/
tools/

# ── Secrets / API keys ────────────────────────────────────────
.env
*.env
*.pem
*.key
*.p12
*.pfx

# Sigstore artifacts (generated by CI — not source files)
*.sig
*.pem

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Windows ───────────────────────────────────────────────────
desktop.ini
$RECYCLE.BIN/

# ── Logs ─────────────────────────────────────────────────────
*.log

# ── PowerShell ────────────────────────────────────────────────
# Compiled script modules (not used here but guard anyway)
*.psm1.bak
*.psd1.bak

# ── What is NEVER ignored (explicitly safe) ───────────────────
# assets/devshield.ico   — required for go build (embed)
# assets/icon.go         — required for go build
# go.mod                 — module definition
# go.sum                 — cryptographic lock file
# scripts/**/*.ps1       — the product itself
# installer/devshield.iss — installer definition
# build.bat              — local build script
# .github/               — CI workflows
